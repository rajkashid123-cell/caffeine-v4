@tailwind base;
@tailwind components;
@tailwind utilities;

@font-face {
  font-family: "Inter";
  src: url("/assets/fonts/Inter.woff2") format("woff2");
  font-display: swap;
}

@font-face {
  font-family: "GeistMono";
  src: url("/assets/fonts/GeistMono.woff2") format("woff2");
  font-display: swap;
}

@font-face {
  font-family: "JetBrains Mono";
  src: url("/assets/fonts/JetBrainsMono.woff2") format("woff2");
  font-display: swap;
}

:root {
  --background: 0.97 0.01 240;
  --foreground: 0.2 0.02 250;
  --card: 0.99 0.005 240;
  --card-foreground: 0.2 0.02 250;
  --popover: 0.99 0.005 240;
  --popover-foreground: 0.2 0.02 250;
  --muted: 0.88 0.006 240;
  --muted-foreground: 0.5 0.03 250;
  --accent: 0.55 0.28 270;
  --accent-foreground: 0.98 0 0;
  --destructive: 0.5 0.2 25;
  --destructive-foreground: 0.98 0 0;
  --border: 0.9 0.02 240;
  --input: 0.98 0 0;
  --ring: 0.55 0.28 270;
  --primary: 0.2 0.02 250;
  --primary-foreground: 0.95 0 0;
  --secondary: 0.65 0.16 70;
  --secondary-foreground: 0.95 0 0;
  --sidebar: 0.92 0.01 240;
  --sidebar-foreground: 0.2 0.02 250;
  --sidebar-primary: 0.55 0.28 270;
  --sidebar-primary-foreground: 0.98 0 0;
  --sidebar-accent: 0.55 0.28 270;
  --sidebar-accent-foreground: 0.98 0 0;
  --sidebar-border: 0.28 0.04 264;
  --sidebar-ring: 0.55 0.28 270;
  --chart-1: 0.55 0.28 270;
  --chart-2: 0.58 0.22 155;
  --chart-3: 0.65 0.26 70;
  --chart-4: 0.65 0.3 20;
  --chart-5: 0.6 0.25 150;
  --color-bg: 0.97 0.01 240;
  --color-surface: 0.99 0.005 240;
  --color-surface-2: 0.96 0.004 240;
  --color-text: 0.2 0.02 250;
  --color-text-muted: 0.5 0.03 250;
  --color-border: 0.9 0.02 240;
  --color-accent: 0.55 0.28 270;
  --color-accent-fg: 0.98 0 0;
  --color-moon: 0.92 0.08 60;
  --color-status-deployed: 0.55 0.2 160;
  --color-status-deployed-bg: 0.9 0.08 160;
  --color-status-building: 0.65 0.16 70;
  --color-status-building-bg: 0.92 0.1 70;
  --color-status-error: 0.5 0.2 25;
  --color-status-error-bg: 0.92 0.1 25;
  --color-status-ready: 0.58 0.12 185;
  --color-status-ready-bg: 0.9 0.06 185;
  --color-status-success: 0.6 0.15 150;
  --color-status-success-bg: 0.9 0.08 150;
  --color-status-warning: 0.65 0.16 70;
  --color-status-warning-bg: 0.92 0.1 70;
  --color-priority-high: 0.5 0.2 25;
  --color-priority-high-bg: 0.92 0.1 25;
  --color-priority-medium: 0.65 0.16 70;
  --color-priority-medium-bg: 0.92 0.1 70;
  --color-priority-low: 0.6 0.15 150;
  --color-priority-low-bg: 0.9 0.08 150;
  --color-maturity-idea: 0.7 0 0;
  --color-maturity-progress: 0.58 0.12 185;
  --color-maturity-live: 0.6 0.15 150;
  --color-maturity-archived: 0.55 0 0;
  --color-entry-build: 0.58 0.12 185;
  --color-entry-rebuild: 0.6 0.15 150;
  --color-entry-deploy: 0.6 0.15 150;
  --color-entry-rollback: 0.5 0.2 25;
  --color-entry-edit: 0.65 0.16 70;
  --color-role-owner: 0.55 0.18 270;
  --color-role-admin: 0.58 0.12 185;
  --color-role-member: 0.55 0.2 240;
  --color-code-bg: 0.92 0 0;
  --color-code-surface: 0.95 0 0;
  --color-code-border: 0.85 0 0;
  --color-code-muted: 0.65 0 0;
  --color-code-text: 0.2 0 0;
  --color-overlay-bg: 0.98 0 0 / 0.85;
  --font-display: Inter;
  --font-body: Inter;
  --font-mono: GeistMono;
  --radius: 6px;
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-full: 9999px;
  --shadow-xs: 0 1px 2px oklch(0 0 0 / 0.06);
  --shadow-sm: 0 2px 6px oklch(0 0 0 / 0.1), 0 1px 2px oklch(0 0 0 / 0.07);
  --shadow-elevated: 0 16px 32px oklch(0 0 0 / 0.12), 0 6px 12px
    oklch(0 0 0 / 0.08);
  --shadow-neon-glow: 0 0 12px oklch(0.95 0.25 130 / 0.4);

  --sidebar-muted-foreground: 0.55 0.01 265;

  --shadow-card: 0 2px 8px oklch(0 0 0 / 0.08), 0 1px 3px oklch(0 0 0 / 0.05);
  --duration-fast: 100ms;
  --duration-base: 150ms;
  --duration-slow: 250ms;
  --easing-base: cubic-bezier(0.4, 0, 0.2, 1);

  --color-lime: 0.88 0.32 130;
  --color-lime-fg: 0.15 0 0;
  --color-indigo: 0.55 0.28 270;
  --color-indigo-fg: 0.98 0 0;
  --color-teal: 0.58 0.22 185;
  --color-teal-fg: 0.98 0 0;
  --color-amber: 0.65 0.26 70;
  --color-amber-fg: 0.12 0 0;
  --color-coral: 0.65 0.3 20;
  --color-coral-fg: 0.98 0 0;

  --manage-health-ok: 0.6 0.15 150;
  --manage-health-ok-bg: 0.94 0.05 150;
  --manage-health-ok-bar: oklch(0.55 0.18 150 / 0.45);
  --manage-health-warn: 0.65 0.16 70;
  --manage-health-warn-bg: 0.96 0.04 70;
  --manage-health-warn-bar: oklch(0.58 0.17 65 / 0.5);
  --manage-health-error: 0.5 0.2 25;
  --manage-health-error-bg: 0.96 0.04 25;

  --launcher-muted-opacity: 0.6;
  --launcher-muted-accent-opacity: 0.5;

  --color-sage: 0.58 0.22 155;
  --color-sage-fg: 0.98 0 0;
  --color-violet: 0.55 0.26 300;
  --color-violet-fg: 0.98 0 0;
}

.dark {
  --background: 0.1 0.018 265;
  --foreground: 0.95 0 0;
  --card: 0.19 0.03 265;
  --card-foreground: 0.95 0 0;
  --popover: 0.22 0.025 265;
  --popover-foreground: 0.95 0 0;
